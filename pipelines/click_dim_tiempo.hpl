  <transform>
    <name>JavaScript</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var meses = [
"",
"Enero",
"Febrero",
"Marzo",
"Abril",
"Mayo",
"Junio",
"Julio",
"Agosto",
"Septiembre",
"Octubre",
"Noviembre",
"Diciembre"
];

nombre_mes = meses[mes];

var dia_semana = fecha.getDay();

if (dia_semana == 0) {
  nombre_dia = "Domingo";
} else if (dia_semana == 1) {
  nombre_dia = "Lunes";
} else if (dia_semana == 2) {
  nombre_dia = "Martes";
} else if (dia_semana == 3) {
  nombre_dia = "Miércoles";
} else if (dia_semana == 4) {
  nombre_dia = "Jueves";
} else if (dia_semana == 5) {
  nombre_dia = "Viernes";
} else if (dia_semana == 6) {
  nombre_dia = "Sábado";
}

es_fin_semana = (dia_semana == 0 || dia_semana == 6);

var fecha_texto =
  anio + "-" +
  ("0" + mes).slice(-2) + "-" +
  ("0" + dia).slice(-2);

es_semana_santa = (
  (
    (fecha_texto >= "2022-04-10" &amp;&amp; fecha_texto &lt;= "2022-04-17") ||
    (fecha_texto >= "2023-04-02" &amp;&amp; fecha_texto &lt;= "2023-04-09") ||
    (fecha_texto >= "2024-03-24" &amp;&amp; fecha_texto &lt;= "2024-03-31") ||
    (fecha_texto >= "2025-04-13" &amp;&amp; fecha_texto &lt;= "2025-04-20") ||
    (fecha_texto >= "2026-03-29" &amp;&amp; fecha_texto &lt;= "2026-04-05")
  )
  &amp;&amp;
  es_fin_semana == true
);</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>nombre_mes</name>
        <rename>nombre_mes</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
