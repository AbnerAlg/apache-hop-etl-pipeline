  </transform>
  <transform>
    <name>Table input</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Click</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT 
    e.pais AS pais_destino,
    p.categoria AS categoria_producto,
    COUNT(*) AS total_pedidos, 
    SUM(f.cantidad) AS volumen_articulos,
    ROUND(AVG(f.total_venta), 2) AS ticket_promedio_dinero,
    SUM(f.total_venta) AS ingresos_totales_logistica
FROM public.fact_ventas f
JOIN public.dim_producto p ON f.id_producto = p.id_producto
JOIN public.dim_pais_envio e ON f.id_pais_envio = e.id_pais_envio
GROUP BY e.pais, p.categoria
ORDER BY ingresos_totales_logistica DESC;</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>240</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
